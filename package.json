{
  "name": "deckwing",
  "version": "0.1.0",
  "description": "AI-powered presentation builder for Rewst",
  "type": "module",
  "bin": {
    "deckwing": "./bin/deckwing.js"
  },
  "files": [
    "bin/",
    "dist/",
    "server/",
    "shared/",
    "src/",
    "index.html",
    "vite.config.js",
    "tailwind.config.js",
    "postcss.config.js",
    "package.json"
  ],
  "scripts": {
    "dev": "vite",
    "dev:full": "concurrently \"npm run server\" \"npm run dev\"",
    "server": "node server/index.js",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node bin/deckwing.js",
    "prepublishOnly": "npm test && npm run build"
  },
  "keywords": ["presentation", "slides", "ai", "claude", "rewst", "msp"],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.84",
    "@anthropic-ai/sdk": "^0.71.2",
    "clsx": "^2.0.0",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.284.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^1.14.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@vitejs/plugin-react": "^5.1.2",
    "autoprefixer": "^10.4.14",
    "concurrently": "^9.2.1",
    "jsdom": "^29.0.1",
    "postcss": "^8.4.27",
    "tailwindcss": "^3.3.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.1"
  }
}
