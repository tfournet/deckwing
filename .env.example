# DeckWing Configuration
#
# Copy to .env:  cp .env.example .env

# ── AI Authentication ─────────────────────────────────────────────────
# Option 1 (default): Install Claude Code + run `claude auth login`
#   No env vars needed — the app uses your Claude Code OAuth session.
#
# Option 2: Anthropic API key (get from https://platform.anthropic.com)
# ANTHROPIC_API_KEY=sk-ant-...

# ── Server ────────────────────────────────────────────────────────────
# PORT=3000
